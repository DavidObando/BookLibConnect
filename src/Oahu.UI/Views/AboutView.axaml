<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Oahu.Core.UI.Avalonia.ViewModels"
             x:Class="Oahu.Core.UI.Avalonia.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             x:CompileBindings="True">

  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
              Spacing="12" Margin="32">
    <TextBlock Text="{Binding AppName}"
               FontSize="28" FontWeight="Bold"
               HorizontalAlignment="Center" />
    <TextBlock Text="{Binding Version, StringFormat='Version {0}'}"
               HorizontalAlignment="Center" FontSize="14" />
    <TextBlock Text="{Binding Description}"
               HorizontalAlignment="Center"
               TextWrapping="Wrap"
               MaxWidth="400" />
    <TextBlock Text="{Binding Copyright}"
               HorizontalAlignment="Center"
               Foreground="{DynamicResource MutedTextBrush}" />
    <TextBlock Text="This software is open source licensed to you under GPL version 3."
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap"
               MaxWidth="400" />
    <Button Click="OpenRepositoryLink"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Cursor="Hand">
      <TextBlock Text="https://github.com/davidobando/oahu"
                 Foreground="{DynamicResource ThemeAccentBrush}"
                 TextDecorations="Underline" />
    </Button>
  </StackPanel>

</UserControl>
