{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oahu.invalid/cli-schemas/v1/config.schema.json",
  "title": "oahu-cli config get",
  "description": "Output of `oahu-cli config get [<key>] --json`. With no key, the document is the full config; with a key, it's a single key/value record.",
  "oneOf": [
    {
      "type": "object",
      "required": ["_schemaVersion", "resource", "download-dir", "default-quality", "max-parallel-jobs", "keep-encrypted-files", "multi-part-download", "export-to-aax", "export-dir", "allow-encrypted-file-credentials"],
      "properties": {
        "_schemaVersion": { "type": "string", "const": "1" },
        "resource": { "type": "string", "const": "config" },
        "download-dir": { "type": "string" },
        "default-quality": { "type": "string", "enum": ["Normal", "High", "Extreme"] },
        "max-parallel-jobs": { "type": "integer", "minimum": 1 },
        "keep-encrypted-files": { "type": "boolean" },
        "multi-part-download": { "type": "boolean" },
        "export-to-aax": { "type": "boolean" },
        "export-dir": { "type": "string" },
        "default-profile-alias": { "type": ["string", "null"] },
        "allow-encrypted-file-credentials": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["_schemaVersion", "resource", "key", "value"],
      "properties": {
        "_schemaVersion": { "type": "string", "const": "1" },
        "resource": { "type": "string", "const": "config-value" },
        "key": { "type": "string" },
        "value": {}
      },
      "additionalProperties": false
    }
  ]
}
