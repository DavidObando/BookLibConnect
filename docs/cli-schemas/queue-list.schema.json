{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oahu.invalid/cli-schemas/v1/queue-list.schema.json",
  "title": "oahu-cli queue list",
  "type": "object",
  "required": ["_schemaVersion", "resource", "count", "items"],
  "properties": {
    "_schemaVersion": { "type": "string", "const": "1" },
    "resource": { "type": "string", "const": "queue" },
    "count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asin", "title", "quality", "addedAt"],
        "properties": {
          "asin": { "type": "string" },
          "title": { "type": "string" },
          "quality": { "type": "string", "enum": ["Normal", "High", "Extreme"] },
          "addedAt": { "type": "string", "format": "date-time" },
          "profileAlias": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
