{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oahu.invalid/cli-schemas/v1/download-summary.schema.json",
  "title": "oahu-cli download (final summary)",
  "type": "object",
  "required": ["_schemaVersion", "resource", "completed", "failed", "canceled", "pending", "jobs"],
  "properties": {
    "_schemaVersion": { "type": "string", "const": "1" },
    "resource": { "type": "string", "const": "download-summary" },
    "completed": { "type": "integer", "minimum": 0 },
    "failed": { "type": "integer", "minimum": 0 },
    "canceled": { "type": "integer", "minimum": 0 },
    "pending": { "type": "integer", "minimum": 0 },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["jobId", "asin", "title", "status"],
        "properties": {
          "jobId": { "type": "string" },
          "asin": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["Queued", "Licensing", "Downloading", "Decrypting", "Muxing", "Completed", "Failed", "Canceled", "Pending"]
          },
          "error": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
