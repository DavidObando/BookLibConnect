<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Oahu.Cli.Tests</RootNamespace>
    <AssemblyName>Oahu.Cli.Tests</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <NoWarn>$(NoWarn);CS1591;SA0001;SA1600;SA1601;SA1602;SA1611;SA1615;SA1623;SA1629;SA1633;SA1652;CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="Spectre.Console.Testing" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Oahu.Cli\Oahu.Cli.csproj" />
    <ProjectReference Include="..\..\src\Oahu.Cli.App\Oahu.Cli.App.csproj" />
    <ProjectReference Include="..\..\src\Oahu.Cli.Tui\Oahu.Cli.Tui.csproj" />
    <ProjectReference Include="..\..\src\Oahu.Cli.Server\Oahu.Cli.Server.csproj" />
  </ItemGroup>

</Project>
